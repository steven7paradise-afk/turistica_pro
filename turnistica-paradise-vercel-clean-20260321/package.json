{
  "name": "turnistica-paradise-pro",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --hostname 0.0.0.0 --port 3001",
    "build": "tsx scripts/build-app.ts",
    "build:netlify": "tsx scripts/build-app.ts",
    "build:vercel": "tsx scripts/build-app.ts",
    "start": "next start --hostname 0.0.0.0 --port 3001",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:bootstrap": "tsx scripts/bootstrap-database.ts",
    "db:bootstrap-neon": "tsx scripts/bootstrap-neon.ts",
    "lint": "next lint",
    "typecheck": "next build",
    "test:shifts": "tsx --test tests/shift-validation.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "next": "^14.2.35",
    "next-auth": "^4.24.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
